{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 40,
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": ["custom/arch", "hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "bluetooth", "network", "battery", "tray", "custom/power", "custom/wallpaper"],

    "custom/arch": {
        "format": "  ",
        "on-click": "wofi --show drun",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "format": "{name}"
    },

    "clock": {
        "format": "{:%H:%M} 󰃭",
        "format-alt": "{:%A, %B %d, %Y} 󰃭",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "󰝟",
        "format-icons": { "default": ["", "", ""] },
        "on-click": "pavucontrol" 
    },

    "bluetooth": {
        "format": "  ",
        "format-disabled": " 󰂲 ",
        "format-connected": " 󰂱 ",
        "on-click": "blueman-manager"
    },

    "custom/power": {
        "format": "⏻ ",
        "on-click": "$HOME/powermenu.sh",
        "tooltip": false
    },

    "network": {
        "format-wifi": "",
        "format-ethernet": "󰈀",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },

"custom/wallpaper": {
    "format": "󰸉",
    "on-click": "~/walltheme.sh",
    "tooltip-format": "Random Wallpaper & Theme"
},

    "tray": {
        "icon-size": 18,
        "spacing": 10
    }
}